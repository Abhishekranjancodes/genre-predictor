pipeline {
    agent any

    environment {
        DOCKER_HUB_USER = 'deadmonk'
        HF_REPO_ID      = 'silvermonkey/roberta-genre-classifier'
        
        DOCKER_HUB_CREDS = credentials('docker-hub-login')
        HF_TOKEN         = credentials('hugging-face-token')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Environment Setup') {
            steps {
                sh 'python3 -m venv venv'
                sh './venv/bin/pip install -r requirements.txt huggingface_hub pytest'
            }
        }

        stage('Automated Unit Tests') {
            steps {
                sh './venv/bin/python3 -m pytest app/model_handler.py'
            }
        }

        stage('Docker Build & Push') {
            steps {
                script {
                    sh "docker build -t ${DOCKER_HUB_USER}/roberta-backend -f Dockerfile.backend ."
                    sh "docker build -t ${DOCKER_HUB_USER}/roberta-frontend -f Dockerfile.frontend ."
                    sh "echo ${DOCKER_HUB_CREDS_PSW} | docker login -u ${DOCKER_HUB_CREDS_USR} --password-stdin"
                    sh "docker push ${DOCKER_HUB_USER}/roberta-backend"
                    sh "docker push ${DOCKER_HUB_USER}/roberta-frontend"
                }
            }
        }

        stage('K8s Deployment') {
            steps {
                sh 'kubectl apply -f k8s/deployment.yaml'
                sh 'kubectl rollout restart deployment/roberta-backend'
                sh 'kubectl rollout restart deployment/roberta-frontend'
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}